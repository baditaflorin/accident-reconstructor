{
  "title": "Accident Reconstructor",
  "schemaVersion": 39,
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP Requests",
      "targets": [
        {
          "expr": "sum(rate(accident_http_requests_total[5m])) by (status)"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Pipeline Duration",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(accident_pipeline_duration_seconds_bucket[5m])) by (le))"
        }
      ]
    }
  ]
}
