{
  "name": "accident-reconstructor",
  "private": false,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "prebuild": "node scripts/write-version.mjs",
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/copy-404.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen:api": "openapi-typescript api/openapi.yaml -o src/api/schema.d.ts",
    "smoke:web": "playwright test"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.9",
    "idb": "^8.0.3",
    "lucide-react": "^1.14.0",
    "openapi-fetch": "^0.17.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "three": "^0.184.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "http-server": "^14.1.1",
    "jsdom": "^29.1.1",
    "npm-run-all": "^4.1.5",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
